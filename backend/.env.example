# Server
PORT=5000
NODE_ENV=development

# Database (MongoDB Atlas recommended in production)
MONGODB_URI=mongodb://localhost:27017/blogs
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/blogs?retryWrites=true&w=majority

# Auth
JWT_ACCESS_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=14d

# Cookies (refresh token). When frontend is on a different domain (Vercel) and
# backend on Render, the cookie must be SameSite=None; Secure — set NODE_ENV=production.
COOKIE_DOMAIN=

# CORS — comma-separated list. Must list exact frontend origin(s), not '*',
# because credentialed (cookie) requests require explicit origin.
CORS_ORIGIN=http://localhost:3000

# Media — uploads are stored on Cloudinary. Create a free account at
# https://cloudinary.com and copy the cloud name, API key, and API secret.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=blogs
MAX_UPLOAD_MB=10

# Admin bootstrap (used by `npm run seed:admin`)
ADMIN_NAME=Site Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Public frontend URL (used for canonical links in JSON-LD, sitemap, etc.)
PUBLIC_SITE_URL=http://localhost:3000
